  <ItemGroup>
    <!--
      First-ever link from the UI project into the engine. WindowsApp.Core
      is a static lib and no longer references WindowsApp.Compute at all
      (it only needs the header-only IComputeBackend/IImageCodec
      interfaces) - this project is now the one place that links
      WindowsApp.Compute/WindowsApp.Vulkan directly, since it's the
      composition root that picks between CudaPipeline (GPU),
      VulkanPipeline (GPU), and CpuComputeBackend (CPU fallback) at
      runtime (see ComputeBackendFactory). WindowsApp.Compute is a dynamic
      lib (CUDA DLL) - CONFIRMED (not just a theoretical risk) that
      WindowsApp.Compute.dll does NOT get copied next to WindowsApp.exe by
      the ProjectReference alone - unlike .NET ProjectReferences, native
      C++ vcxproj-to-vcxproj references don't auto-copy the referenced
      DLL into a dependent project's output folder, and WindowsApp.exe's
      $(OutDir) (a WinUI/packaging-project convention, nested under its
      own project subfolder) differs from WindowsApp.Compute's own
      default $(OutDir). This bit an actual unpackaged-exe run (missing
      export at load time from a stale copy of the DLL) before the
      CopyComputeDllToOutput target below was added. WindowsApp.Vulkan is
      a static lib, so it doesn't have this problem either - its code
      links straight into WindowsApp.exe. turbojpeg.dll was assumed here
      to app-locally deploy on its own via vcpkg's manifest-mode MSBuild
      integration - CONFIRMED WRONG 2026-07-22 (the first time anyone
      actually launched the unpackaged exe interactively in this
      project's history): it does not get copied either, failing with
      STATUS_DLL_NOT_FOUND at launch. See CopyVcpkgDllsToOutput below.
    -->
    <ProjectReference Include="..\..\WindowsApp.Core\WindowsApp.Core.vcxproj">
      <Project>{d6b1d440-6228-4444-a1a1-9a9eb2d12b11}</Project>
    </ProjectReference>
    <ProjectReference Include="..\..\WindowsApp.Compute\WindowsApp.Compute.vcxproj">
      <Project>{c7b1d440-7228-4444-b2b2-9a9eb2d12b12}</Project>
    </ProjectReference>
    <!-- WindowsApp.Vulkan is a static lib (unlike WindowsApp.Compute's
         CUDA DLL) - its object code links directly into WindowsApp.exe,
         so there's no equivalent "must copy the DLL into the packaged
         output" concern for the Vulkan tier. -->
    <ProjectReference Include="..\..\WindowsApp.Vulkan\WindowsApp.Vulkan.vcxproj">
      <Project>{f1b1d440-9228-4444-d4d4-9a9eb2d12b14}</Project>
    </ProjectReference>
  </ItemGroup>

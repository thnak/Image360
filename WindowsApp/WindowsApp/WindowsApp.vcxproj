  <!--
    See the comment on the WindowsApp.Compute ProjectReference above: native
    C++ project references don't copy their DLL output into a dependent
    project's own $(OutDir) the way .NET ProjectReferences do, and
    WindowsApp.Compute's default OutDir differs from this project's. Without
    this, an unpackaged WindowsApp.exe run can silently load a stale
    WindowsApp.Compute.dll left over from an earlier build/copy, failing at
    load time with a missing-export error rather than a clear file-not-found.
  -->
  <Target Name="CopyComputeDllToOutput" AfterTargets="AfterBuild" Condition="Exists('$(SolutionDir)$(Platform)\$(Configuration)\WindowsApp.Compute.dll')">
    <Copy SourceFiles="$(SolutionDir)$(Platform)\$(Configuration)\WindowsApp.Compute.dll" DestinationFolder="$(OutDir)" SkipUnchangedFiles="false" />
  </Target>
  <!--
    turbojpeg.dll (JpegCodec's vcpkg dependency, pulled in transitively
    via WindowsApp.Core.lib) - see the ProjectReference comment above:
    vcpkg's manifest-mode AppLocal deployment was assumed to handle this
    automatically but does NOT, confirmed 2026-07-22 by actually
    launching the unpackaged exe (STATUS_DLL_NOT_FOUND). Same fix shape
    as CopyComputeDllToOutput - vcpkg's own per-configuration bin dir.
  -->
  <PropertyGroup>
    <VcpkgRuntimeBinDir Condition="'$(Configuration)'=='Debug'">$(SolutionDir)vcpkg_installed\x64-windows\x64-windows\debug\bin\</VcpkgRuntimeBinDir>
    <VcpkgRuntimeBinDir Condition="'$(Configuration)'!='Debug'">$(SolutionDir)vcpkg_installed\x64-windows\x64-windows\bin\</VcpkgRuntimeBinDir>
  </PropertyGroup>
  <Target Name="CopyVcpkgDllsToOutput" AfterTargets="AfterBuild" Condition="Exists('$(VcpkgRuntimeBinDir)turbojpeg.dll')">
    <Copy SourceFiles="$(VcpkgRuntimeBinDir)turbojpeg.dll" DestinationFolder="$(OutDir)" SkipUnchangedFiles="false" />
  </Target>
</Project>
<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WindowsApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WindowsApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WindowsApp">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel Spacing="2">
                <TextBlock Text="Panorama Stitcher"
                           Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Pick a set of overlapping RAW photos and stitch them into one panorama."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="24"
              ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <Grid>
                    <Grid.Background>
                        <AcrylicBrush TintOpacity="0.08" />
                    </Grid.Background>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <Grid>
                            <Rectangle Fill="{ThemeResource LayerFillColorDefaultBrush}" />
                            <!-- Shows the panorama canvas as it's built: each
                                 render chunk is blitted into this bitmap in
                                 place as its task completes (see
                                 MainWindow::OnRenderTaskCompleted), so the
                                 picture fills in progressively instead of
                                 only appearing once the whole stitch is
                                 done. -->
                            <Image x:Name="RenderPreviewImage"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" />

                            <StackPanel x:Name="EmptyStatePanel"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                <FontIcon Glyph="&#xE91B;"
                                          FontSize="44"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <TextBlock Text="No stitch yet"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Use Start Stitch to pick RAW photos (RAF, CR2, NEF, ARW, DNG)."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextWrapping="WrapWholeWords"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    VerticalAlignment="Top">
                <StackPanel Spacing="12">
                    <TextBlock Text="Panorama Stitch"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ComboBox x:Name="ComputeBackendComboBox"
                              Header="Compute backend"
                              SelectedIndex="0"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="ComputeBackendComboBox_SelectionChanged">
                        <ComboBoxItem Content="Auto (recommended)" />
                        <ComboBoxItem Content="CUDA (NVIDIA)" />
                        <ComboBoxItem Content="Vulkan" />
                        <ComboBoxItem Content="CPU" />
                    </ComboBox>
                    <TextBlock x:Name="StitchStatusText"
                               Text="No stitch running."
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords" />
                    <ProgressBar x:Name="StitchProgressBar"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="StitchStartButton"
                                Content="Start Stitch"
                                Click="StitchStartButton_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch" />
                        <Button x:Name="StitchCancelButton"
                                Grid.Column="1"
                                Content="Cancel"
                                IsEnabled="False"
                                Click="StitchCancelButton_Click"
                                HorizontalAlignment="Stretch" />
                    </Grid>
                    <Button x:Name="StitchExportButton"
                            Content="Export Preview JPEG"
                            IsEnabled="False"
                            Click="StitchExportButton_Click"
                            HorizontalAlignment="Stretch" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

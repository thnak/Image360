<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WindowsApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WindowsApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WindowsApp">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel Spacing="2">
                <!-- Text set dynamically from code-behind (see
                     MainWindow::UpdateFeatureChrome) so it reflects
                     whichever feature FeatureComboBox has selected,
                     instead of a hardcoded "Panorama Stitcher" title that
                     would mislead once MFNR/HDR+/Night Sight/Super Res
                     Zoom are also reachable from this window. -->
                <TextBlock x:Name="HeaderTitleText"
                           Text="Panorama Stitcher"
                           Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="HeaderSubtitleText"
                           Text="Pick a set of overlapping RAW photos and stitch them into one panorama."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="24"
              ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <Grid>
                    <Grid.Background>
                        <AcrylicBrush TintOpacity="0.08" />
                    </Grid.Background>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <Grid>
                            <Rectangle Fill="{ThemeResource LayerFillColorDefaultBrush}" />
                            <!-- Shows the result as it's built. Stitch:
                                 each render chunk is blitted into this
                                 bitmap in place as its task completes
                                 (see MainWindow::OnRenderTaskCompleted),
                                 so the picture fills in progressively.
                                 Burst modes (MFNR/HDR+/Night Sight/Super
                                 Res Zoom): no chunk grid, no known output
                                 size until BURST_MERGE runs, so this stays
                                 empty until BURST_FINISH completes, then
                                 the whole result is blitted in one shot
                                 (see MainWindow::ShowFinalBurstResult). -->
                            <Image x:Name="RenderPreviewImage"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" />

                            <StackPanel x:Name="EmptyStatePanel"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                <FontIcon Glyph="&#xE91B;"
                                          FontSize="44"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <TextBlock Text="No result yet"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Pick a feature, then use Start to choose photos (a single overlapping set for Stitch, a burst of frames for the others)."
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextWrapping="WrapWholeWords"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    VerticalAlignment="Top">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="FeatureCardTitle"
                               Text="Panorama Stitch"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ComboBox x:Name="FeatureComboBox"
                              Header="Feature"
                              SelectedIndex="0"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="FeatureComboBox_SelectionChanged">
                        <ComboBoxItem Content="Panorama Stitch" />
                        <ComboBoxItem Content="MFNR (noise reduction)" />
                        <ComboBoxItem Content="HDR+" />
                        <ComboBoxItem Content="Night Sight" />
                        <ComboBoxItem Content="Super Res Zoom" />
                    </ComboBox>
                    <ComboBox x:Name="ComputeBackendComboBox"
                              Header="Compute backend"
                              SelectedIndex="0"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="ComputeBackendComboBox_SelectionChanged">
                        <ComboBoxItem Content="Auto (recommended)" />
                        <ComboBoxItem Content="CUDA (NVIDIA)" />
                        <ComboBoxItem Content="Vulkan" />
                        <ComboBoxItem Content="CPU" />
                    </ComboBox>
                    <TextBlock x:Name="RunStatusText"
                               Text="No run in progress."
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords" />
                    <ProgressBar x:Name="RunProgressBar"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="RunStartButton"
                                Content="Start"
                                Click="RunStartButton_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch" />
                        <Button x:Name="RunCancelButton"
                                Grid.Column="1"
                                Content="Cancel"
                                IsEnabled="False"
                                Click="RunCancelButton_Click"
                                HorizontalAlignment="Stretch" />
                    </Grid>
                    <Button x:Name="ExportButton"
                            Content="Export Result"
                            IsEnabled="False"
                            Click="ExportButton_Click"
                            HorizontalAlignment="Stretch" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
